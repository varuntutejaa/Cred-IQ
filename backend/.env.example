FLASK_ENV=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-another-long-random-string

# MongoDB — local or Atlas connection string
MONGO_URI=mongodb://localhost:27017/crediq

# Firebase Admin SDK — download from Firebase Console → Project Settings → Service Accounts
# Option 1: paste the entire JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option 2: path to the downloaded JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# GitHub Personal Access Token (https://github.com/settings/tokens)
# Needs: read:user, public_repo
GITHUB_ACCESS_TOKEN=ghp_your_token_here

# AI providers (optional)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173
